{
  "name": "employee-monitor",
  "version": "1.0.0",
  "description": "Employee monitoring app with screenshots and input tracking",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start:next": "next start",
    "start": "electron .",
    "build:electron": "electron-builder",
    "build:linux": "electron-builder --linux AppImage deb",
    "build:linux:arm64": "electron-builder --linux AppImage deb --arm64",
    "build:portable-win": "electron-packager . \"Time Tracker\" --platform=win32 --arch=x64 --out portable-dist --overwrite --asar --prune=false",
    "lint": "eslint",
    "migrate:s3": "node scripts/migrate-mongo-to-s3.js"
  },
  "keywords": [],
  "author": {
    "name": "Beyond Billions",
    "email": "support@beyondbillions.com"
  },
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "googleapis": "^169.0.0",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "mongodb": "^7.0.0",
    "next": "16.0.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "screenshot-desktop": "^1.15.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.beyondbillions.tracker",
    "productName": "Time Tracker",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "zip"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Beyond Billions <support@beyondbillions.com>",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
